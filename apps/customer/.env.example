# Copy this file to ".env" next to app.json (same folder). Then: npx expo start -c
#
# Another laptop or phone (same Wi‑Fi as the PC running QMS.Api):
#   EXPO_PUBLIC_API_URL=http://<API_PC_LAN_IP>:5154
#   On the API PC run: dotnet run --urls "http://0.0.0.0:5154" and allow TCP 5154 in firewall.
#
# Android emulator on the SAME machine as the API: default is 10.0.2.2 — you can omit .env or use:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:5154
#
EXPO_PUBLIC_API_URL=http://127.0.0.1:5154
